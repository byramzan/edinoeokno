# Сервер
NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# База данных
DATABASE_URL=postgresql://app:secret@localhost:5432/edinoe_okno

# JWT
JWT_SECRET=change_this_to_a_256_bit_random_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Файлы
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@chesu.ru
SMTP_PASS=your_smtp_password
EMAIL_FROM="Единое Окно ЧГУ <noreply@chesu.ru>"

# Внешняя БД (для будущей интеграции)
EXTERNAL_DB_ENABLED=false
EXTERNAL_DB_URL=
SYNC_INTERVAL_MINUTES=60

# Университет
UNIVERSITY_NAME=ЧГУ им. А.А. Кадырова
RECTOR_NAME=Магомедов Заур Айндиевич
